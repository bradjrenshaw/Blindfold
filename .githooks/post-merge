#!/bin/sh
# Refresh the mod's version stamp so the in-game update check compares the
# right commit. Installed by scripts/deploy.ps1 via
# `git config core.hooksPath .githooks`. The same one-liner runs from every
# hook where HEAD moves: post-merge (pull), post-commit, post-checkout, and
# post-rewrite (rebase/amend).
printf 'main@%s' "$(git rev-parse --short=7 HEAD)" > src/version
